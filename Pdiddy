-- ─── CHEAT DETECTOR ───────────────────────────
local function r43_0(player, localPlayer)
    if player==localPlayer then return end
    if Cheaters[player.Name] then return end
    local r1_5=RS.Players:FindFirstChild(player.Name) if not r1_5 then return end
    local r2_5=r1_5:FindFirstChild("Status") if not r2_5 then return end
    r2_5=r2_5:FindFirstChild("Journey") if not r2_5 then return end
    local statsNode=r2_5:FindFirstChild("Statistics") if not statsNode then return end
    local deaths=statsNode:GetAttribute("Deaths") or 0 if deaths==0 then deaths=1 end
    local kills=statsNode:GetAttribute("Kills") or 0 if kills==0 then kills=1 end
    local kdr=math.floor(kills/deaths*10)/10
    local hours=math.floor((statsNode:GetAttribute("TimePlayed") or 0)/3600)
    local isPremium=false
    pcall(function()
        local passes=r1_5:FindFirstChild("Status")
        passes=passes and passes:FindFirstChild("Purchases")
        passes=passes and passes:FindFirstChild("Passes")
        if passes then
            for _,attr in ipairs(passes:GetAttributes()) do
                if passes:GetAttribute(attr)==true then isPremium=true break end
            end
        end
    end)
    local function flag(tag,reason)
        Cheaters[player.Name]=true cheaterKDR[player.Name]=kdr
        espReason[player.Name]=tag.." "..reason
        addToList(player.Name,tag,reason)
        sendNotif("Cheat | Detector ("..tag..")","Player: "..player.Name.." suspected! ("..reason..")",5)
        print("Cheat Detector ("..tag..") "..player.Name.." "..reason)
    end
    if kills>=15 and kdr>=5 then flag("CHEATER(100%)","KDR:"..kdr) return end
    if kills>=400 and hours<30 then flag("CHEATER(G)","K:"..kills.." H:"..hours) return end
    if kills>=250 and hours<20 then flag("CHEATER(H)","K:"..kills.." H:"..hours) return end
    if isPremium then
        if kdr>=3 and hours<100  then flag("CHEATER(KDR+)","KDR:"..kdr.." H:"..hours) return end
        if kdr>=2 and hours<=50  then flag("CHEATER(KDR+)","KDR:"..kdr.." H:"..hours) return end
        if hours<5 and kdr>2.5   then flag("CHEATER(KDR+)","H:"..hours.." KDR:"..kdr) return end
    else
        if kdr>=3 and hours<100  then flag("CHEATER(KDR)","KDR:"..kdr.." H:"..hours) return end
        if kdr>=2 and hours<=50  then flag("CHEATER(KDR)","KDR:"..kdr.." H:"..hours) return end
        if hours<5 and kdr>2.5   then flag("CHEATER(KDR)","H:"..hours.." KDR:"..kdr) return end
    end
end

