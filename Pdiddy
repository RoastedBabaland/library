-- ─── MOVE GUI ─────────────────────────────────
local function moveGUI(nx,ny)
    PX=nx PY=ny
    for _,e in ipairs(allObjs) do
        if e.isLine then e.obj.From=Vector2.new(PX,PY+e.oy) e.obj.To=Vector2.new(PX+PW,PY+e.oy)
        else e.obj.Position=Vector2.new(PX+e.ox,PY+e.oy) end
    end
    g.btnBg.Position=Vector2.new(PX+PW-BTN_SIZE-3,PY+6)
    g.btnTx.Position=Vector2.new(PX+PW-BTN_SIZE-3+3,PY+6)
    g.tabBg.Position=Vector2.new(PX,PY)
    g.tabBdr.Position=Vector2.new(PX,PY)
    g.tabTx.Position=Vector2.new(PX+6,PY+3)
end

local function setGuiVisible(open)
    guiOpen=open
    for _,e in ipairs(allObjs) do e.obj.Visible=open end
    g.btnBg.Visible=open g.btnTx.Visible=open
    g.tabBg.Visible=not open g.tabBdr.Visible=not open g.tabTx.Visible=not open
    if open then moveGUI(PX,PY)
    else
        for i=1,MAX_ROWS do
            g.rows[i].name.Visible=false g.rows[i].tag.Visible=false
            g.rows[i].reason.Visible=false g.rows[i].bg.Visible=false
        end
    end
end

local function refreshGUI()
    if not guiOpen then return end
    local mods,cheats=0,0
    for _,e in ipairs(flaggedList) do
        if e.tag:sub(1,3)=="MOD" then mods=mods+1 else cheats=cheats+1 end
    end
    g.footer.Text="◄ "..mods.." mods  |  "..cheats.." cheaters  ►"
    g.espLbl.Text=modFound and "ESP: OFF" or "ESP: ON"
    g.espLbl.Color=modFound and Color3.fromRGB(255,60,60) or C_GREEN
    local maxScroll=math.max(0,#flaggedList-MAX_ROWS)
    if scrollOffset>maxScroll then scrollOffset=maxScroll end
    for i=1,MAX_ROWS do
        local row=g.rows[i] local e=flaggedList[i+scrollOffset]
        if e then
            row.name.Text=e.name row.tag.Text=e.tag row.reason.Text=e.reason or ""
            row.tag.Color=tagColor(e.tag)
            row.name.Color=e.tag:sub(1,3)=="MOD" and Color3.fromRGB(255,60,60) or C_WHITE
            row.name.Visible=true row.tag.Visible=true row.reason.Visible=true
        else row.name.Visible=false row.tag.Visible=false row.reason.Visible=false end
    end
end

