local function applyRecoil(on)
    pcall(function()
        for _,ammo in ipairs(RS.AmmoTypes:GetChildren()) do
            local d=AMMO_DEFAULTS[ammo.Name]
            if on then
                ammo:SetAttribute("RecoilStrength",0)
            else
                if d and d.RecoilStrength then ammo:SetAttribute("RecoilStrength",d.RecoilStrength) end
            end
        end
    end)
end
local function applySpread(on)
    pcall(function()
        for _,ammo in ipairs(RS.AmmoTypes:GetChildren()) do
            local d=AMMO_DEFAULTS[ammo.Name]
            if on then
                ammo:SetAttribute("ProjectileDrop",0)
                ammo:SetAttribute("MuzzleVelocity",9999)
                ammo:SetAttribute("Drag",0.001)
                if ammo:GetAttribute("AccuracyDeviation")~=nil then
                    ammo:SetAttribute("AccuracyDeviation",0)
                end
            else
                if d then
                    ammo:SetAttribute("ProjectileDrop",d.ProjectileDrop)
                    ammo:SetAttribute("MuzzleVelocity",d.MuzzleVelocity)
                    ammo:SetAttribute("Drag",d.Drag)
                    if d.AccuracyDeviation then ammo:SetAttribute("AccuracyDeviation",d.AccuracyDeviation) end
                end
            end
        end
    end)
end

