local BODY_PARTS={Head=true,LeftFoot=true,LeftHand=true,LeftLowerArm=true,LeftLowerLeg=true,
    LeftUpperArm=true,LeftUpperLeg=true,LowerTorso=true,RightFoot=true,
    RightHand=true,RightLowerArm=true,RightUpperArm=true,RightUpperLeg=true,UpperTorso=true}
local function r46_0()
    local localPlayer=getLocalPlayer()
    for _,r4 in ipairs(getPlayers()) do
        pcall(r43_0,r4,localPlayer)
        if not r4.Character then continue end
        if not modWarnings[r4.Name] then modWarnings[r4.Name]=1 end
        if not Moderators[r4.Name] and not checkedPremium[r4.Name] then
            pcall(function()
                local s=RS.Players:FindFirstChild(r4.Name) s=s and s:FindFirstChild("Status")
                local gv=s and s:FindFirstChild("GameplayVariables")
                if gv and gv:GetAttribute("GodMode")==true then
                    Moderators[r4.Name]=true espReason[r4.Name]="MOD(POSSIBLE) GodMode"
                    addToList(r4.Name,"MOD(POSSIBLE)","GodMode") onModDetected(r4.Name)
                    sendNotif("Possible Mod (GodMode)",r4.Name.." has GodMode!",8)
                end
            end)
        end
        if modWarnings[r4.Name]<5 then
            pcall(function()
                local char=r4.Character
                local hum=char:FindFirstChildOfClass("Humanoid")
                if not hum or hum.Health<=0 then return end
                local state=hum:GetState()
                if state==Enum.HumanoidStateType.Dead then return end
                if state==Enum.HumanoidStateType.None then return end
                if state==Enum.HumanoidStateType.GettingUp then return end
                for _,p in pairs(char:GetChildren()) do
                    if BODY_PARTS[p.Name] and 1<=p.Transparency then
                        Moderators[r4.Name]=true modWarnings[r4.Name]=modWarnings[r4.Name]+1
                        espReason[r4.Name]="MOD(INVIS) Invis"
                        addToList(r4.Name,"MOD(INVIS)","Invis") onModDetected(r4.Name)
                        sendNotif("Mod Detector (B)","Mod Detected: "..r4.Name)
                        sendNotif("Mod Detector (B)","Mod Detected: "..r4.Name)
                        sendNotif("Mod Detector (B)","Mod Detected: "..r4.Name)
                        return
                    end
                end
            end)
        end
        checkedPremium[r4.Name]=true
    end
end

-- ─── ESP ──────────────────────────────────────
local espObjs={}
-- cache flaggedList as a dict for O(1) lookup instead of O(n) search every frame
local flaggedDict={}
local function updateESP()
    -- rebuild dict from flaggedList (only changes when someone is flagged)
    flaggedDict={}
    for _,fe in ipairs(flaggedList) do flaggedDict[fe.name]=fe end
    local active={}
    for _,player in ipairs(getPlayers()) do
        local isMod=Moderators[player.Name] local isCheat=Cheaters[player.Name]
        if not(isMod or isCheat) then continue end
        active[player.Name]=true
        local char,hrp
        pcall(function() char=player.Character hrp=char and char:FindFirstChild("HumanoidRootPart") end)
        if not hrp then
            if espObjs[player.Name] then espObjs[player.Name].tag.Visible=false end
            continue
        end
        local sp,on=WorldToScreen(hrp.Position+Vector3.new(0,3.4,0))
        if not espObjs[player.Name] then
            local t=Drawing.new("Text")
            t.Font=Drawing.Fonts.SystemBold t.Size=12 t.Outline=true t.Center=true t.Visible=false
            espObjs[player.Name]={tag=t}
        end
        local e=espObjs[player.Name]
        local fe=flaggedDict[player.Name]
        local playerTag=fe and fe.tag or nil
        local playerReason=fe and fe.reason or ""
        local col=tagColor(playerTag or "")
        if on then
            local label
            if playerTag and playerTag:sub(1,3)=="MOD" then label="MOD"
            else
                local kdr=playerReason:match("KDR:([%d%.]+)")
                local h=playerReason:match("H:([%d]+)")
                if kdr and h then label="CHEATER  KD:"..kdr.."  H:"..h
                elseif kdr then label="CHEATER  KD:"..kdr
                else label="CHEATER" end
            end
            if e.tag.Text~=label then e.tag.Text=label end
            if e.tag.Color~=col then e.tag.Color=col end
            e.tag.Position=Vector2.new(sp.X,sp.Y-13)
            if not e.tag.Visible then e.tag.Visible=true end
        else
            if e.tag.Visible then e.tag.Visible=false end
        end
    end
    for name,e in pairs(espObjs) do if not active[name] then e.tag.Visible=false end end
end

