local allObjs={}
local function regLine(obj,oy) table.insert(allObjs,{obj=obj,oy=oy,isLine=true}) return obj end
local function regObj(obj,ox,oy) table.insert(allObjs,{obj=obj,ox=ox,oy=oy,isLine=false}) return obj end
local function sq(x,y,w,h,col,filled,corner,trans)
    local s=Drawing.new("Square") s.Position=Vector2.new(x,y) s.Size=Vector2.new(w,h)
    s.Color=col s.Filled=filled~=false s.Corner=corner or 0 s.Transparency=trans or 1 s.Visible=true return s
end
local function tx(str,x,y,sz,col,outline,font)
    local t=Drawing.new("Text") t.Text=str t.Position=Vector2.new(x,y) t.Size=sz or 13
    t.Color=col or C_WHITE t.Outline=outline~=false t.Center=false
    t.Font=font or Drawing.Fonts.System t.Visible=true return t
end
local function ln(x1,y1,x2,y2,col)
    local l=Drawing.new("Line") l.From=Vector2.new(x1,y1) l.To=Vector2.new(x2,y2)
    l.Color=col or C_BORDER l.Thickness=1 l.Visible=true return l
end

